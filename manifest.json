{
  "manifest_version": 3,
  "name": "LinkedIn Request Filter",
  "version": "1.0",
  "description": "Accept LinkedIn requests based on filters",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Filter"
  }
}